# Vercel Environment Variables Setup
# Import this project at https://vercel.com/new and set these values:

# Database URL (SQLite file in /tmp for Vercel ephemeral filesystem)
# For production on Vercel, consider upgrading to PostgreSQL
DATABASE_URL="file:/tmp/hrd-system/production.db"

# Or use PostgreSQL for persistent data:
# DATABASE_URL="postgresql://user:password@host:5432/hrd_system"

# Node environment
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://hrd-system.vercel.app"